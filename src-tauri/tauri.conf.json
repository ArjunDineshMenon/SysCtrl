{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SysCtrl",
  "version": "0.1.0",
  "identifier": "com.sysctrl.app",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "SysCtrl",
        "width": 900,
        "height": 600,
        "url": "index.html"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage"],
    "icon": ["icons/icon.png"]
  }
}